# OpenClaw Monitor backend defaults
CLAWMON_DATA_ROOT=~/.openclaw/agents
CLAWMON_DB_PATH=./data/clawmon.db
CLAWMON_ENRICHMENT_ENABLED=false
CLAWMON_ENRICHMENT_BUDGET_USD=0.25
CLAWMON_ENRICHMENT_PROVIDER=local
CLAWMON_ENRICHMENT_MODEL=local-heuristic-v1
CLAWMON_OPENAI_API_KEY=
CLAWMON_OPENAI_BASE_URL=https://api.openai.com/v1
CLAWMON_ENRICHMENT_TIMEOUT_SECONDS=30
# Optional pricing for provider-backed enrichment spend tracking.
# Values are USD per 1M tokens for prompt (input) and completion (output).
CLAWMON_ENRICHMENT_INPUT_COST_PER_1M_USD=0
CLAWMON_ENRICHMENT_OUTPUT_COST_PER_1M_USD=0
